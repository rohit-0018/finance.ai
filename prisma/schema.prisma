generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model users {
  id           String         @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  username     String         @unique
  password     String
  is_admin     Boolean        @default(false)
  blocked      Boolean        @default(false)
  display_name String?
  created_at   DateTime       @default(now()) @db.Timestamptz()
  saved_papers saved_papers[]
  notes        notes[]
  qa_history   qa_history[]
  papers       papers[]       @relation("added_by")
  rss_feeds    rss_feeds[]    @relation("feed_added_by")
  fetch_log    fetch_log[]    @relation("fetched_by")
  articles     articles[]     @relation("article_added_by")
  user_topics  user_topics[]
  daily_briefs daily_briefs[]
}

model rss_feeds {
  id              String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  name            String
  url             String    @unique
  topic           String    @default("AI")
  color           String    @default("#6366f1")
  active          Boolean   @default(true)
  approved        Boolean   @default(false)
  added_by        String?   @db.Uuid
  last_fetched_at DateTime? @db.Timestamptz()
  created_at      DateTime  @default(now()) @db.Timestamptz()
  added_by_user   users?    @relation("feed_added_by", fields: [added_by], references: [id], onDelete: SetNull)
  papers          papers[]
}

model papers {
  id            String         @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  external_id   String         @unique
  title         String
  authors       String?
  year          Int?
  source        String         @default("arXiv")
  category      String?
  topic         String         @default("AI")
  abstract      String?
  problem       String?
  method        String?
  finding       String?
  tags          Json           @default("[]")
  url           String?
  analysis      Json?
  feed_id       String?        @db.Uuid
  added_by      String?        @db.Uuid
  approved      Boolean        @default(true)
  fetched_at    DateTime       @default(now()) @db.Timestamptz()
  created_at    DateTime       @default(now()) @db.Timestamptz()
  feed          rss_feeds?     @relation(fields: [feed_id], references: [id], onDelete: SetNull)
  added_by_user users?         @relation("added_by", fields: [added_by], references: [id], onDelete: SetNull)
  saved_papers  saved_papers[]
  notes         notes[]
  qa_history    qa_history[]
}

model saved_papers {
  id          String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  user_id     String   @db.Uuid
  paper_id    String   @db.Uuid
  read_status String   @default("unread")
  saved_at    DateTime @default(now()) @db.Timestamptz()
  user        users    @relation(fields: [user_id], references: [id], onDelete: Cascade)
  paper       papers   @relation(fields: [paper_id], references: [id], onDelete: Cascade)

  @@unique([user_id, paper_id])
}

model notes {
  id         String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  user_id    String   @db.Uuid
  paper_id   String   @db.Uuid
  content    String
  highlight  String?
  note_type  String   @default("note")
  created_at DateTime @default(now()) @db.Timestamptz()
  updated_at DateTime @default(now()) @db.Timestamptz()
  user       users    @relation(fields: [user_id], references: [id], onDelete: Cascade)
  paper      papers   @relation(fields: [paper_id], references: [id], onDelete: Cascade)
}

model qa_history {
  id         String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  user_id    String   @db.Uuid
  paper_id   String   @db.Uuid
  role       String
  content    String
  created_at DateTime @default(now()) @db.Timestamptz()
  user       users    @relation(fields: [user_id], references: [id], onDelete: Cascade)
  paper      papers   @relation(fields: [paper_id], references: [id], onDelete: Cascade)
}

model fetch_log {
  id           String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  source       String
  topic        String?
  papers_count Int      @default(0)
  errors       String?
  fetched_by   String?  @db.Uuid
  created_at   DateTime @default(now()) @db.Timestamptz()
  user         users?   @relation("fetched_by", fields: [fetched_by], references: [id], onDelete: SetNull)
}

model articles {
  id         String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  url        String   @unique
  title      String
  content    String
  summary    String?
  topic      String   @default("General")
  tags       Json     @default("[]")
  analysis   Json?
  added_by   String?  @db.Uuid
  created_at DateTime @default(now()) @db.Timestamptz()
  user       users?   @relation("article_added_by", fields: [added_by], references: [id], onDelete: SetNull)
}

model user_topics {
  id         String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  user_id    String   @db.Uuid
  topic      String
  rating     Int      @default(3)
  created_at DateTime @default(now()) @db.Timestamptz()
  user       users    @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([user_id, topic])
}

model daily_briefs {
  id          String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  user_id     String   @db.Uuid
  content     String
  topics      Json     @default("[]")
  paper_count Int      @default(0)
  read        Boolean  @default(false)
  created_at  DateTime @default(now()) @db.Timestamptz()
  user        users    @relation(fields: [user_id], references: [id], onDelete: Cascade)
}
