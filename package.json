{
  "name": "papermind",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:push": "prisma db push",
    "db:pull": "prisma db pull",
    "db:studio": "prisma studio",
    "db:generate": "prisma generate",
    "db:seed": "prisma db seed",
    "db:migrate": "prisma migrate dev",
    "db:reset": "prisma migrate reset",
    "life:db:push": "prisma db push --config prisma.life.config.ts",
    "life:db:force:push": "prisma db push --config prisma.life.config.ts --force-reset",
    "life:db:pull": "prisma db pull --config prisma.life.config.ts",
    "life:db:studio": "prisma studio --config prisma.life.config.ts",
    "life:db:generate": "prisma generate --config prisma.life.config.ts",
    "life:db:migrate": "prisma migrate dev --config prisma.life.config.ts",
    "life:db:reset": "prisma migrate reset --config prisma.life.config.ts"
  },
  "dependencies": {
    "@fullcalendar/core": "^6.1.20",
    "@fullcalendar/daygrid": "^6.1.20",
    "@fullcalendar/interaction": "^6.1.20",
    "@fullcalendar/list": "^6.1.20",
    "@fullcalendar/react": "^6.1.20",
    "@fullcalendar/timegrid": "^6.1.20",
    "@supabase/supabase-js": "^2.49.1",
    "@tanstack/react-query": "^5.64.1",
    "date-fns": "^4.1.0",
    "openai": "^6.33.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hot-toast": "^2.5.1",
    "react-router-dom": "^6.28.1",
    "recharts": "^3.8.1",
    "zod": "^3.24.1",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@prisma/client": "^7.6.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "dotenv": "^17.4.0",
    "jsdom": "^25.0.1",
    "prisma": "^7.6.0",
    "typescript": "^5.7.3",
    "vite": "^5.4.14",
    "vitest": "^2.1.8"
  }
}
